# =============================
# ENV
# =============================
NODE_ENV=development
PORT=5005

# =============================
# DATABASE
# =============================
MONGODB_URI=mongodb://localhost:27017/carboy_dev

# =============================
# ADMIN BACKEND
# =============================
ADMIN_BASE_URL=http://localhost:5000/api/admin

# =============================
# CORS
# =============================
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# =============================
# TIMEOUTS
# =============================
ADMIN_TIMEOUT_MS=10000

# =============================
# LOGGING
# =============================
LOG_LEVEL=info

# =============================
# ADMIN SERVICE AUTH
# =============================
ADMIN_EMAIL=admin@carboy.dev
ADMIN_PASSWORD=Admin@123456

# =============================
# API BASE URLs
# =============================
# For localhost development (no ngrok):
APP_BASE_URL=http://localhost:5005

# For ngrok or production (external access for webhooks):
# Leave empty for localhost, set to ngrok URL when using ngrok
PUBLIC_BASE_URL=https://earringed-cindie-unresurrected.ngrok-free.dev

# =============================
# RAZORPAY PAYMENT
# =============================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
